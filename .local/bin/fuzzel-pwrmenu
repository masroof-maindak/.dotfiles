#!/usr/bin/env bash

declare -A actions=(
    ["Lock screen"]="gtklock"
    ["Log out // Quit Niri"]="niri msg action quit"
    ["Reboot // Restart"]="reboot"
    ["Shutdown // Poweroff"]="poweroff"
)

SELECTION=$(printf "%s\n" "${!actions[@]}" | fuzzel --dmenu -l 4) || exit 0
eval "${actions[$SELECTION]}"
